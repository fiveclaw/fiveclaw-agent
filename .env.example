# FiveClaw Agent Configuration
# Copy to .env and fill in your values.
# Get your API key at https://fiveclaw.xyz/dashboard/keys

# ── Required ──────────────────────────────────────────────────────────────────
FIVECLAW_API_KEY=fc_live_your_key_here

# ── FiveM Server Path (auto-detected if not set) ──────────────────────────────
# FIVEM_PROJECT_ROOT=/path/to/your/fivem-server

# ── txAdmin Panel ─────────────────────────────────────────────────────────────
# TXADMIN_URL=http://localhost:40120
# TXADMIN_TOKEN=your-master-actions-token

# ── MySQL (for mysql_query tool) ──────────────────────────────────────────────
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=your_database

# ── SSH Deployment (for deploy_resource) ─────────────────────────────────────
# FIVEM_SSH_HOST=your.server.ip
# FIVEM_SSH_USER=ubuntu
# FIVEM_SSH_KEY=/home/you/.ssh/id_ed25519
# FIVEM_REMOTE_RESOURCES_DIR=/home/ubuntu/fivem/resources

# ── Agent Port (default: 5200) ────────────────────────────────────────────────
# PORT=5200
